# ------------------------------
# n8n runtime configuration
# ------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678
GENERIC_TIMEZONE=Asia/Kolkata
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string

# Optional but recommended auth for local n8n UI
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# ------------------------------
# Ollama model configuration
# ------------------------------
OLLAMA_MODEL=llama3:8b
OLLAMA_KEEP_ALIVE=24h

# ------------------------------
# Email credentials (create in n8n Credentials UI)
# These values are documented for setup/testing and submission.
# ------------------------------
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=your-email@example.com
IMAP_PASSWORD=your-imap-password

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_SECURE=false

# Loop prevention: responder address to ignore
AUTO_REPLY_EMAIL=your-email@example.com

# Prefix used by IF condition to avoid re-replying
AUTO_REPLY_SUBJECT_MARKER=AI Auto-Reply:
